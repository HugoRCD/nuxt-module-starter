{
  "name": "nuxt-module-starter",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/your-module.git"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev --filter=my-module-playground",
    "dev:prepare": "turbo dev:prepare",
    "dev:docs": "turbo dev --filter=my-module-docs",
    "build": "turbo build",
    "build:module": "turbo build --filter=my-module",
    "build:docs": "turbo build --filter=my-module-docs",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "automd": "automd --config .github/automd.json"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.11.0",
    "@types/node": "latest",
    "automd": "^0.4.0",
    "eslint": "^9.39.1",
    "turbo": "^2.6.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.1.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
